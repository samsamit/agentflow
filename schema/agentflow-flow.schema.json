{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "maxRevisions": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "requires": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "generates": {
            "type": "string"
          },
          "generateStrategy": {
            "type": "string",
            "enum": [
              "replace",
              "update",
              "version"
            ]
          },
          "subagent": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "string"
              }
            ]
          },
          "context": {
            "type": "object",
            "properties": {
              "instructions": {
                "type": "string"
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "instructions"
            ],
            "additionalProperties": false
          },
          "validates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "name",
          "context"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "name",
    "steps"
  ],
  "additionalProperties": false
}