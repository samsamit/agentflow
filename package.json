{
  "name": "@samsamit/agentflow",
  "version": "1.2.0",
  "description": "Workflow manager for agentic use",
  "homepage": "https://github.com/samsamit/agentflow#readme",
  "bugs": {
    "url": "https://github.com/samsamit/agentflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samsamit/agentflow.git"
  },
  "license": "MIT",
  "author": "Samu Tiainen",
  "type": "module",
  "main": "dist/index.mjs",
  "bin": {
    "agentflow": "dist/index.mjs"
  },
  "files": [
    "dist",
    "schema",
    "flows",
    "skills"
  ],
  "scripts": {
    "build": "tsdown && node dist/scripts/generate-schema.mjs",
    "watch": "tsdown --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "biome check --write --unsafe src",
    "validate": "tsc --noEmit && npm run check && npm run test:run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^14.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
